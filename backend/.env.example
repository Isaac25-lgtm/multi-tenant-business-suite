# Local development
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-this-in-local-dev

# Leave empty to use SQLite locally.
# Set a PostgreSQL connection string for production-like local testing.
DATABASE_URL=

# Uploads
UPLOAD_FOLDER=static/uploads
MAX_CONTENT_LENGTH=5242880

# Optional session override
# SESSION_COOKIE_SECURE=0
