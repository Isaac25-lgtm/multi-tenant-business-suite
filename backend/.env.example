# =============================================================================
# Denove APS — Local Development Environment
# =============================================================================
# Copy this file to .env and fill in your local PostgreSQL credentials.
#
#   cp .env.example .env
#
# PostgreSQL is REQUIRED for both local development and production.
# SQLite is not supported.
# =============================================================================

FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-this-to-a-random-string-for-local-dev

# ---- PostgreSQL (choose ONE method) ----------------------------------------

# Method 1: Full connection URL (takes precedence)
# DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/denove_aps

# Method 2: Individual PG* variables (assembled into a URL automatically)
PGUSER=postgres
PGPASSWORD=yourpassword
PGHOST=localhost
PGPORT=5432
PGDATABASE=denove_aps

# ---- Uploads ----------------------------------------------------------------
UPLOAD_FOLDER=static/uploads
MAX_CONTENT_LENGTH=5242880

# ---- AI / LLM Provider (OpenAI-compatible) ----------------------------------
# All AI features degrade gracefully if these are not set.
AI_ENABLED=false
AI_API_KEY=
AI_BASE_URL=https://api.deepseek.com/v1
AI_CHAT_MODEL=deepseek-chat
# Leave blank unless your AI provider exposes a real vision-capable model.
# For OCR, you can also configure a separate OCR_* provider below.
AI_VISION_MODEL=
AI_TIMEOUT_SECONDS=15
AI_MAX_TOKENS=1024

# Feature toggles
AI_DAILY_BRIEFING_ENABLED=true
AI_MANAGER_CHAT_ENABLED=true

# ---- OCR / Vision (Anthropic recommended for OCR; separate from DeepSeek) ---
OCR_ENABLED=false
# OCR_PROVIDER=anthropic
# OCR_API_KEY=
# OCR_BASE_URL=https://api.anthropic.com
# OCR_MODEL=claude-3-5-haiku-latest
# OCR_DAILY_CLIENT_LIMIT=5
# OCR_WARNING_CLIENT_NUMBER=3
# If you want OCR to use the main AI provider instead, leave OCR_PROVIDER as
# openai_compatible and set AI_VISION_MODEL or OCR_MODEL to a real vision model.

# ---- Optional overrides -----------------------------------------------------
# SESSION_COOKIE_SECURE=0
